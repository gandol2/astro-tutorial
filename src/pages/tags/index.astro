---
import BaseLayout from '../../layouts/BaseLayout.astro';
const allPosts = Object.values(import.meta.glob('../posts/*.md', { eager: true })); // ./posts 디렉토리의 모든 *.md(Markdown) 파일을 가져와서 배열 만듬
const tags = [...new Set(allPosts.map((post: any) => post.frontmatter.tags).flat())];   // 모든 게시물의 태그를 가져와서 중복 제거 후 배열로 만듬
// console.log(tags);  // 디버깅용 출력
const pageTitle = "Tag Index";
---
<BaseLayout pageTitle={pageTitle}>
    <div class="tags">
        {tags.map((tag) => (
            <p class="tag"><a href={`/tags/${tag}`}>#{tag}</a></p>
        ))}
    </div>
</BaseLayout>


<style>
    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .tag {
        margin: 0;
        background-color: #0070f330;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
    }
    .tag > a {
        text-decoration: none;
        color: #0070f3;
        font-weight: bold;
    }
    .tag > a:hover {
        text-decoration: underline;
    }
</style>